<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet + network state -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service for live location sharing -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Vibracija za SOS notifikaciju -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Activity Recognition — Google's API koristi senzore (akcelerometar) da detektuje
         hodanje/vožnju/mirovanje. FGS koristi to da prilagodi interval GPS-a (čuva bateriju
         kad se ne kreće, češći fix kad vozi). A10+ traži runtime permission. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="com.google.android.gms.permission.ACTIVITY_RECOGNITION" />

    <!-- SOS full-screen notifikacija — budi ekran kad telefon zaključan. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Battery exemption (optional, but FGS reliability) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Boot receiver — resume sharing after reboot if user opted in -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Android Auto — POI (Points of Interest) kategorija. Semantika Krug-a je pokazivanje
         lokacija clanova kruga + Places pin-ova, sto je tacno definicija POI. Prednosti:
         - Google Maps automatski render-uje mapu (bez SurfaceCallback-a i custom tile
           rendering-a koji NAVIGATION zahteva)
         - Play Store review prolazi glatko (POI = tacna kategorija, NAVIGATION bi bio
           odbijen jer Krug ne pruza turn-by-turn)
         - Sa Unknown Sources ON u dev/debug + production sa Play Store approval, POI apps
           se ISO prikazuju u Auto launcher-u kao standalone ikone (kao Yelp, ChargePoint,
           itd.). Ranija pretpostavka da POI apps "launch-uju iz Maps-a" bila je pogresna. -->
    <uses-permission android:name="androidx.car.app.MAP_TEMPLATES" />

    <!-- NAPOMENA: NE deklariši `android.hardware.type.automotive` uses-feature.
         Ta oznaka je za Android Automotive OS (native car OS ugradjen u vozilu, npr.
         Volvo/Polestar). Krug koristi Android Auto (projection sa telefona) preko
         com.google.android.gms.car.application meta-data-e. Play Store odbija AAB
         ako se oba deklariraju istovremeno (uzajamno isključivi target-i). -->

    <application
        android:name=".KrugApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Krug"
        tools:targetApi="36">

        <meta-data
            android:name="com.mapbox.token"
            android:value="${MAPBOX_PUBLIC_TOKEN}" />

        <!-- Android Auto host metadata — pokazuje na automotive_app_desc.xml. -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

        <!-- Minimum Car App API level koji podržavamo. Level 4 = Auto 8.1+ (2023+).
             Level 1 (Auto 5.0, 2015) je bio prestari — moderni Auto host-ovi ignorišu apps
             sa preniskim api level-om jer se predpostavlja da su napusteni. -->
        <meta-data
            android:name="androidx.car.app.minCarApiLevel"
            android:value="4" />

        <!-- Macrobenchmark zahtev: shell="true" omogućava :benchmark modulu (ADB shell)
             da instrumentira proces app-a u release/benchmark build-u bez debuggable=true.
             Bez ovog tag-a, macrobenchmark puca sa "Profileable not enabled". -->
        <profileable android:shell="true" />

        <service
            android:name=".core.location.LocationTrackingService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- FCM service. Firebase Messaging library auto-detektuje po intent-filter-u.
             Cloud Functions šalje high-priority data message-eve ovamo kad neko klikne
             Refresh za nas ili triggeruje SOS. Bez ovog service-a, push-evi bi Firebase
             SDK silently discard-ovao. Handles Doze wakeup: FCM je Google-owned pa
             zaobilazi standardne Doze restrikcije. -->
        <service
            android:name=".core.messaging.KrugMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Activity Recognition receiver — Google detect transition broadcasts. -->
        <receiver
            android:name=".core.location.ActivityRecognitionReceiver"
            android:exported="false" />

        <!-- Geofence transition receiver — Google Play Services enter/exit broadcasts. -->
        <receiver
            android:name=".core.places.GeofenceBroadcastReceiver"
            android:exported="false" />

        <!-- Android Auto — CarAppService (Navigation template). Auto host bind-uje kad
             telefon konektuje sa autom preko USB/wireless. exported=true jer Auto host
             (odvojen proces) treba da bind-uje.

             NEMA foregroundServiceType — CarAppService NIJE user foreground service; Auto
             host sam upravlja lifecycle-om. Prisustvo foregroundServiceType je često uzrok
             zbog kojeg Auto host odbije da list-uje app u meniju. -->
        <service
            android:name=".core.car.KrugCarAppService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <category android:name="androidx.car.app.category.POI" />
            </intent-filter>
        </service>

        <!-- Boot + package replaced receiver — restart FGS automatski. -->
        <receiver
            android:name=".core.location.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Krug.Splash">
            <!-- showWhenLocked/turnScreenOn se NE postavljaju ovde — to bi značilo da
                 mapa može da se prikaže preko lock screen-a pri svakom launch-u (privacy
                 leak). Umesto toga, MainActivity ih programmatic-ki uključuje SAMO kad
                 dolazi preko SOS full-screen intent-a (videti handleSosFocusExtra). -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link: krug://invite/{code} -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="krug"
                    android:host="invite" />
            </intent-filter>
        </activity>
    </application>
</manifest>
