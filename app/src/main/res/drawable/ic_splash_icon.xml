<?xml version="1.0" encoding="utf-8"?>
<!--
    Splash screen icon. Android 12+ splash render-uje icon u krug od 192dp sa
    safe zone-om ~160dp. Novi logo (4 figure) ima više belog prostora po ivicama
    nego stari (6 figura) pa može manji inset = veći logo na splash-u bez sečenja.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/krug_logo"
    android:inset="10dp" />
