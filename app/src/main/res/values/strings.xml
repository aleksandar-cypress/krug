    <!-- Onboarding: info slides -->
    <string name="onb_welcome_title">Welcome to Krug</string>
    <string name="onb_welcome_body">An app that connects you with people who matter. No ads, no payments</string>

    <string name="onb_how_title">How Krug works</string>
    <string name="onb_how_body">Create a circle, invite family or friends with a code, and see where everyone is on the map in real time</string>

    <string name="onb_privacy_title">You control what you share</string>
    <string name="onb_privacy_body">Only members of your circles see your location. You can pause sharing or leave a circle at any time</string>

    <!-- Onboarding: permissions -->
    <string name="onb_loc_title">Location access</string>
    <string name="onb_loc_body">Krug needs your location to share it with members of your circles. This is the app\'s core function</string>
    <string name="onb_loc_grant">Allow location access</string>
    <string name="onb_loc_open_settings">Open settings</string>

    <string name="onb_bg_title">Always-on location</string>
    <string name="onb_bg_body">To stay visible even when the app is closed, choose \"Allow all the time\" in system settings</string>
    <string name="onb_bg_open_settings">Open system settings</string>

    <string name="activity_rec_title">Battery-smart activity tracking</string>
    <string name="activity_rec_body">Krug can detect when you\'re walking, driving, or still, and adjust how often it shares your location. Better accuracy in motion, longer battery when you\'re parked.</string>
