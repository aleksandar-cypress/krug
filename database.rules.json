{
  "rules": {
    "locations": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['lat','lng','updatedAt'])",
        "lat":        { ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90" },
        "lng":        { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
        "accuracy":   { ".validate": "newData.isNumber()" },
        "batteryPct": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
        "isCharging": { ".validate": "newData.isBoolean()" },
        "updatedAt":  { ".validate": "newData.isNumber()" },
        "$other":     { ".validate": false }
      }
    },
    "sos": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['lat','lng','triggeredAt'])",
        "lat":         { ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90" },
        "lng":         { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
        "triggeredAt": { ".validate": "newData.isNumber()" },
        "message":     { ".validate": "newData.isString() || !newData.exists()" },
        "$other":      { ".validate": false }
      }
    },
    "locationRequests": {
      "$targetUid": {
        ".read": "auth != null && auth.uid === $targetUid",
        "$requesterUid": {
          ".write": "auth != null && (auth.uid === $requesterUid || auth.uid === $targetUid)",
          ".validate": "newData.isNumber() || !newData.exists()"
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
